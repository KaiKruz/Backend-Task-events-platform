{
  "info": {
    "_postman_id": "a1b2c3d4-events-platform",
    "name": "Events Platform",
    "description": "Submission-ready collection for Events Platform API through Phase 6. Configure variables and run Auth first to obtain tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "event_id", "value": "" },
    { "key": "enrollment_id", "value": "" },
    { "key": "facilitator_event_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/signup/",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seeker@example.com\",\n  \"password\": \"StrongPass9!\",\n  \"role\": \"seeker\"\n}"
            },
            "url": "{{base_url}}/api/auth/signup/",
            "description": "Allowed roles: seeker or facilitator. OTP is sent via configured email backend."
          },
          "response": []
        },
        {
          "name": "POST /api/auth/verify-email/",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seeker@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{base_url}}/api/auth/verify-email/",
            "description": "Replace OTP with the code from signup."
          },
          "response": []
        },
        {
          "name": "POST /api/auth/login/",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body.access) pm.collectionVariables.set('access_token', body.access);",
                  "  if (body.refresh) pm.collectionVariables.set('refresh_token', body.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seeker@example.com\",\n  \"password\": \"StrongPass9!\"\n}"
            },
            "url": "{{base_url}}/api/auth/login/",
            "description": "Requires verified email. Saves access/refresh tokens to collection variables."
          },
          "response": []
        },
        {
          "name": "POST /api/auth/refresh/",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body.access) pm.collectionVariables.set('access_token', body.access);",
                  "  if (body.refresh) pm.collectionVariables.set('refresh_token', body.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/refresh/",
            "description": "Refreshes JWT access token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Public / seeker",
      "item": [
        {
          "name": "GET /api/health/",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/health/",
            "description": "Health check endpoint."
          },
          "response": []
        },
        {
          "name": "GET /api/events/",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/events/?location=&language=&starts_after=&starts_before=&q=&page=1&page_size=20",
            "description": "Public list with optional filters. Pagination shape: count/next/previous/results."
          },
          "response": []
        },
        {
          "name": "GET /api/events/{id}/",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/events/{{event_id}}/",
            "description": "Public detail endpoint."
          },
          "response": []
        },
        {
          "name": "POST /api/events/{id}/enroll/",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{base_url}}/api/events/{{event_id}}/enroll/",
            "description": "Verified seeker only."
          },
          "response": []
        },
        {
          "name": "GET /api/me/enrollments/upcoming/",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/me/enrollments/upcoming/",
            "description": "Verified seeker only. Active enrollments with starts_at >= now."
          },
          "response": []
        },
        {
          "name": "GET /api/me/enrollments/past/",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/me/enrollments/past/",
            "description": "Verified seeker only. Active enrollments with starts_at < now."
          },
          "response": []
        },
        {
          "name": "POST /api/me/enrollments/{id}/cancel/",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{base_url}}/api/me/enrollments/{{enrollment_id}}/cancel/",
            "description": "Verified seeker; own enrollment only."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Facilitator",
      "item": [
        {
          "name": "POST /api/facilitator/events/",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Facilitator Event\",\n  \"description\": \"Deep dive session\",\n  \"language\": \"en\",\n  \"location\": \"Cairo\",\n  \"starts_at\": \"2026-12-01T10:00:00Z\",\n  \"ends_at\": \"2026-12-01T12:00:00Z\",\n  \"capacity\": 25\n}"
            },
            "url": "{{base_url}}/api/facilitator/events/",
            "description": "Verified facilitator only."
          },
          "response": []
        },
        {
          "name": "GET /api/facilitator/events/",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/facilitator/events/",
            "description": "List authenticated facilitator's own events."
          },
          "response": []
        },
        {
          "name": "GET /api/facilitator/events/{id}/",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/facilitator/events/{{facilitator_event_id}}/",
            "description": "Retrieve an owned event."
          },
          "response": []
        },
        {
          "name": "PATCH /api/facilitator/events/{id}/",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Facilitator Event (updated)\",\n  \"capacity\": 30\n}"
            },
            "url": "{{base_url}}/api/facilitator/events/{{facilitator_event_id}}/",
            "description": "Partial update for an owned event."
          },
          "response": []
        },
        {
          "name": "DELETE /api/facilitator/events/{id}/",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/facilitator/events/{{facilitator_event_id}}/",
            "description": "Delete an owned event."
          },
          "response": []
        },
        {
          "name": "GET /api/facilitator/events/my-summary/",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/facilitator/events/my-summary/",
            "description": "Shows total_active_enrollments and available_seats for owned events."
          },
          "response": []
        }
      ]
    }
  ]
}
