{
  "info": {
    "_postman_id": "a1b2c3d4-events-platform",
    "name": "Events Platform",
    "description": "Events Platform backend API. Set collection variables: base_url, then run Auth flow; tokens can be saved from Login/Refresh test scripts. For capacity-full test: create an event with capacity 1, enroll seeker A, then call Enroll as seeker B.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "event_id", "value": "" },
    { "key": "enrollment_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST signup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seeker@example.com\",\n  \"password\": \"StrongPass9!\",\n  \"role\": \"seeker\"\n}"
            },
            "url": "{{base_url}}/api/auth/signup/",
            "description": "Roles: seeker | facilitator. Check server console for 6-digit OTP (default email backend)."
          },
          "response": []
        },
        {
          "name": "POST verify-email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seeker@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{base_url}}/api/auth/verify-email/",
            "description": "Replace otp with the code from the signup email."
          },
          "response": []
        },
        {
          "name": "POST login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    if (j.access) { pm.collectionVariables.set('access_token', j.access); }",
                  "    if (j.refresh) { pm.collectionVariables.set('refresh_token', j.refresh); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seeker@example.com\",\n  \"password\": \"StrongPass9!\"\n}"
            },
            "url": "{{base_url}}/api/auth/login/",
            "description": "Requires verified email. Test script stores access_token and refresh_token on success."
          },
          "response": []
        },
        {
          "name": "POST refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    if (j.access) { pm.collectionVariables.set('access_token', j.access); }",
                  "    if (j.refresh) { pm.collectionVariables.set('refresh_token', j.refresh); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/refresh/",
            "description": "SimpleJWT refresh. Test script updates access_token (and refresh if rotated)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "GET list",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/events/?location=nyc&language=en&starts_after=&starts_before=&q=&page=1&page_size=20",
            "description": "Public. location/language: case-insensitive exact match on full field. q: substring on title or description."
          },
          "response": []
        },
        {
          "name": "GET detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/events/{{event_id}}/",
            "description": "Public. Set event_id (integer PK)."
          },
          "response": []
        },
        {
          "name": "POST enroll",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{base_url}}/api/events/{{event_id}}/enroll/",
            "description": "Verified seeker only. Empty JSON body. 201 on success."
          },
          "response": []
        },
        {
          "name": "POST enroll — capacity full (expect 400 envelope)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 400 when event is at capacity', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Error envelope detail + code', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('detail');",
                  "    pm.expect(json).to.have.property('code');",
                  "    pm.expect(json.code).to.eql('validation_error');",
                  "});",
                  "pm.test('Detail mentions capacity', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(String(json.detail).toLowerCase()).to.include('capacity');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{base_url}}/api/events/{{event_id}}/enroll/",
            "description": "Setup: event with capacity 1, another seeker already enrolled; call as second seeker with Bearer token. Expect 400 { detail, code: validation_error }."
          },
          "response": []
        },
        {
          "name": "GET detail — missing event (expect 404 envelope)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 404', function () { pm.response.to.have.status(404); });",
                  "pm.test('Error envelope', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('detail');",
                  "    pm.expect(json).to.have.property('code');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/events/999999999/",
            "description": "Optional: proves missing event returns 404 with assignment error shape."
          },
          "response": []
        }
      ]
    },
    {
      "name": "My Enrollments",
      "item": [
        {
          "name": "GET upcoming",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/me/enrollments/upcoming/",
            "description": "Verified seeker only. Active enrollments for events with starts_at >= now (UTC)."
          },
          "response": []
        },
        {
          "name": "GET upcoming — facilitator blocked (expect 403 envelope)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 403 for facilitator', function () { pm.response.to.have.status(403); });",
                  "pm.test('Error envelope', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('detail');",
                  "    pm.expect(json).to.have.property('code');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/me/enrollments/upcoming/",
            "description": "Optional: use access_token for a verified facilitator. Expect 403."
          },
          "response": []
        },
        {
          "name": "GET past",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/me/enrollments/past/",
            "description": "Verified seeker only. Active enrollments for events with starts_at < now (UTC)."
          },
          "response": []
        },
        {
          "name": "POST cancel",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    if (j.id) { pm.collectionVariables.set('enrollment_id', String(j.id)); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{base_url}}/api/me/enrollments/{{enrollment_id}}/cancel/",
            "description": "Verified seeker; own enrollment only. Set enrollment_id."
          },
          "response": []
        },
        {
          "name": "POST cancel — missing enrollment (expect 404 envelope)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 404', function () { pm.response.to.have.status(404); });",
                  "pm.test('Error envelope', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('detail');",
                  "    pm.expect(json).to.have.property('code');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{base_url}}/api/me/enrollments/999999999/cancel/",
            "description": "Optional: verified seeker; enrollment id does not exist."
          },
          "response": []
        }
      ]
    }
  ]
}
