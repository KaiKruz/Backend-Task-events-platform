DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Assignment target DB (PostgreSQL). Example:
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/events_platform
# If omitted, project falls back to local SQLite (db.sqlite3).
DATABASE_URL=

DEFAULT_FROM_EMAIL=no-reply@example.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true

PAGE_SIZE=20

ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7
# Optional override. If empty, JWT uses DJANGO_SECRET_KEY.
JWT_SIGNING_KEY=

OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
